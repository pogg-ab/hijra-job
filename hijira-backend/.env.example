APP_NAME="Hijra Global API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hijra_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=private
QUEUE_CONNECTION=database
DB_QUEUE_TABLE=queue_jobs

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,localhost:5173,127.0.0.1,127.0.0.1:3001,127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001
L5_SWAGGER_CONST_HOST=http://127.0.0.1:8000
INTERNAL_SOFTWARE_WEBHOOK_URL=

SEED_SUPER_ADMIN_NAME="Hijra Super Admin"
SEED_SUPER_ADMIN_EMAIL=superadmin@hijra.local
SEED_SUPER_ADMIN_PHONE=+251911111111
SEED_SUPER_ADMIN_PASSWORD=Password@123

SEED_STAFF_NAME="Hijra Staff"
SEED_STAFF_EMAIL=staff@hijra.local
SEED_STAFF_PHONE=+251922222222
SEED_STAFF_PASSWORD=Password@123

SEED_SEEKER_NAME="Hijra User"
SEED_SEEKER_EMAIL=user@hijra.local
SEED_SEEKER_PHONE=+251933333333
SEED_SEEKER_PASSWORD=Password@123

SEED_PARTNER_NAME="Hijra Foreign Partner"
SEED_PARTNER_EMAIL=partner@hijra.local
SEED_PARTNER_PHONE=+251944444444
SEED_PARTNER_PASSWORD=Password@123
SEED_PARTNER_COMPANY="Hijra Partner Agency LLC"

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@hijra.global"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
